# Omnissa Access Approvals — ZimaCube env file (complete reference)
# Lives at /media/ZIMARAID/omnissa-approvals/omnissa-approvals.env, chmod 600.
#
# REQUIRED values are uncommented — fill them in before starting.
# OPTIONAL values are commented out with their default shown; uncomment to override.

# ══ REQUIRED ═══════════════════════════════════════════════════════════════════

# ── Omnissa Access service client (approvals API) ────────────────────────────
# Tenant hostname, no scheme (e.g. tenant.us1.wss.workspaceone.com)
OMNISSA_BOOTSTRAP_URL=tenant.us1.wss.workspaceone.com
# Service client (Client Credentials grant) created in the Access console
OMNISSA_BOOTSTRAP_CLIENT_ID=ApprovalService
# Secret of the service client above
OMNISSA_BOOTSTRAP_CLIENT_SECRET=

# ── First-run local admin (created only when the user table is empty) ────────
# Username of the initial local admin account
OMNISSA_BOOTSTRAP_ADMIN_USERNAME=admin
# Password of the initial local admin account
OMNISSA_BOOTSTRAP_ADMIN_PASSWORD=
# Email address of the initial local admin account
OMNISSA_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# ── Admin OAuth2 login (Omnissa Access as OIDC IdP) ──────────────────────────
# OIDC client ID (User Access Token, Authorization Code + PKCE) from Access
OMNISSA_ADMIN_OAUTH_CLIENT_ID=ApprovalAdmin
# Secret of the OIDC client above
OMNISSA_ADMIN_OAUTH_CLIENT_SECRET=
# Redirect URI registered on the OIDC client (public hostname, not the backend)
OMNISSA_ADMIN_OAUTH_REDIRECT_URI=https://approvals.example.com/login/oauth2/code/omnissa
# OIDC issuer: https://<tenant>/SAAS/auth — the issuer from
# /.well-known/openid-configuration, NOT /acs
OMNISSA_ADMIN_OAUTH_ISSUER_URI=https://tenant.us1.wss.workspaceone.com/SAAS/auth

# ══ OPTIONAL (defaults shown) ══════════════════════════════════════════════════

# ── Admin OAuth2 extras ───────────────────────────────────────────────────────
# Set true after confirming OAuth2 login works to auto-disable the Access consent screen
#OMNISSA_ADMIN_OAUTH_DISABLE_CONSENT=false

# ── Authentication ────────────────────────────────────────────────────────────
# Set true to disable local username/password login (OAuth2-only admin login)
#OMNISSA_AUTH_LOCAL_LOGIN_DISABLED=false

# ── Callout endpoint security ─────────────────────────────────────────────────
# Require HTTP Basic auth on POST /api/approvals/new (blank = open endpoint)
#OMNISSA_API_USERNAME=
# Password paired with OMNISSA_API_USERNAME
#OMNISSA_API_PASSWORD=
# Max callout requests per minute per client IP on /api/approvals/new (0 = unlimited)
#OMNISSA_API_RATE_LIMIT=60

# ── Server ────────────────────────────────────────────────────────────────────
# HTTP port the app listens on inside the container
#SERVER_PORT=8081

# ── SMTP mail notifications ───────────────────────────────────────────────────
# SMTP server hostname (blank = mail notifications disabled)
#SPRING_MAIL_HOST=
# SMTP port
#SPRING_MAIL_PORT=587
# SMTP authentication username
#SPRING_MAIL_USERNAME=
# SMTP authentication password
#SPRING_MAIL_PASSWORD=
# Sender (From) address — must be accepted by the relay (default no-reply@example.com)
#SPRING_MAIL_FROM=approvals-noreply@example.com
# Set true for SMTP servers requiring STARTTLS (e.g. Gmail on 587)
#SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false

# ── Webhook notifications ─────────────────────────────────────────────────────
# POST to this webhook when a new activation request arrives (blank = disabled)
#WEBHOOK_URL=
# Payload format: generic (JSON event) | slack | teams
#WEBHOOK_FORMAT=generic

# ── Syslog export ─────────────────────────────────────────────────────────────
# Syslog server to forward application logs to (blank = disabled)
#SYSLOG_HOST=
# Syslog port — a port NUMBER only (e.g. 514); the transport is set by SYSLOG_PROTOCOL
#SYSLOG_PORT=514
# Transport: udp (default) | tcp | tls
#SYSLOG_PROTOCOL=udp

# ── Syslog TLS (only used when SYSLOG_PROTOCOL=tls) ───────────────────────────
# Client cert + key enable mutual TLS (set BOTH or neither). The key must be
# unencrypted PKCS#8 ("BEGIN PRIVATE KEY"; convert with `openssl pkcs8 -topk8 -nocrypt`).
# A CA bundle overrides the platform trust store (for private/self-signed server certs).
# *_FILE variants are container paths and take precedence over the inline *_PEM
# variants — put the files under /app/data/certs/ (the persistent volume).
# Inline client certificate PEM
#SYSLOG_CLIENT_CERT_PEM=
# Inline client private key PEM (unencrypted PKCS#8)
#SYSLOG_CLIENT_KEY_PEM=
# Inline CA certificate bundle PEM (may hold multiple certs)
#SYSLOG_CA_PEM=
# Client certificate file path, e.g. /app/data/certs/syslog-client.crt
#SYSLOG_CLIENT_CERT_FILE=
# Client private key file path, e.g. /app/data/certs/syslog-client.key
#SYSLOG_CLIENT_KEY_FILE=
# CA bundle file path, e.g. /app/data/certs/syslog-ca.crt
#SYSLOG_CA_FILE=
