# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Deployment mode ──────────────────────────────────────────────────────────
# Caddy mode: set your public hostname (DNS must point here for Let's Encrypt)
APPROVAL_DOMAIN=approvals.flaming.ws

# ── Omnissa Access — Service client (approvals API) ──────────────────────────
OMNISSA_BOOTSTRAP_URL=<tenant>.wss.workspaceone.com
OMNISSA_BOOTSTRAP_CLIENT_ID=<service-client-id>
OMNISSA_BOOTSTRAP_CLIENT_SECRET=

# ── First-run local admin account ────────────────────────────────────────────
# Auto-created on first startup when the user table is empty.
# Remove or leave blank to skip (OAuth2 login will still work if configured below).
OMNISSA_BOOTSTRAP_ADMIN_USERNAME=admin
OMNISSA_BOOTSTRAP_ADMIN_PASSWORD=
OMNISSA_BOOTSTRAP_ADMIN_EMAIL=admin@approvals.flaming.ws

# ── Admin OAuth2 login (optional — Omnissa Access as OIDC IdP) ───────────────
# Required Omnissa Access client config:
#   Type: User Access Token (Confidential)
#   Grant: Authorization Code + PKCE
#   Scopes: openid email profile
#   Redirect URI: https://approvals.flaming.ws/login/oauth2/code/omnissa
OMNISSA_ADMIN_OAUTH_CLIENT_ID=
OMNISSA_ADMIN_OAUTH_CLIENT_SECRET=
OMNISSA_ADMIN_OAUTH_REDIRECT_URI=https://approvals.flaming.ws/login/oauth2/code/omnissa
OMNISSA_ADMIN_OAUTH_ISSUER_URI=
# Set to true to automatically disable the Omnissa Access consent screen on the OIDC
# client above. Requires ApprovalService to have admin rights. Leave false on first run
# (a tip will appear in the logs); enable once you have confirmed login works.
OMNISSA_ADMIN_OAUTH_DISABLE_CONSENT=false

# ── SSL (standalone mode only — not needed with Caddy) ───────────────────────
# Password for config/keystore.p12
# Run scripts/import-cert.sh or scripts/gen-dev-cert.sh to create the keystore.
SSL_KEYSTORE_PASSWORD=changeit

# ── SMTP (optional — for approval email notifications) ───────────────────────
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
