# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Deployment mode ──────────────────────────────────────────────────────────
# Caddy mode: set your public hostname
APPROVAL_DOMAIN=approval.yourdomain.com

# ── Omnissa Access — Service client (API calls) ──────────────────────────────
OMNISSA_BOOTSTRAP_URL=dean.us1.wss.workspaceone.com
OMNISSA_BOOTSTRAP_CLIENT_ID=ApprovalService
OMNISSA_BOOTSTRAP_CLIENT_SECRET=

# ── SSL (standalone mode only — not needed with Caddy) ───────────────────────
# Password for config/keystore.p12
# Run scripts/import-cert.sh or scripts/gen-dev-cert.sh to create the keystore.
SSL_KEYSTORE_PASSWORD=changeit

# ── SMTP ─────────────────────────────────────────────────────────────────────
SPRING_MAIL_HOST=smtp.yourdomain.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
